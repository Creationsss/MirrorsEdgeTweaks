<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net8.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
		<UseWPF>true</UseWPF>
		<UseWindowsForms>true</UseWindowsForms>
		<ImplicitUsings>enable</ImplicitUsings>
		<ApplicationIcon>Icon.ico</ApplicationIcon>
		<ApplicationManifest>app.manifest</ApplicationManifest>
		<IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
		
		<!-- Version Information -->
		<Version>4.4.2</Version>
		<AssemblyVersion>4.4.2.0</AssemblyVersion>
		<FileVersion>4.4.2.0</FileVersion>
		<InformationalVersion>4.4.2</InformationalVersion>
	</PropertyGroup>

	<ItemGroup>
	  <Resource Include="Icon.ico">
	  </Resource>
	</ItemGroup>

	<ItemGroup>
	  <EmbeddedResource Include="Versions\*.json" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Eliot.UELib" Version="1.12.0" />
		<PackageReference Include="NativeSharpLzo" Version="0.3.5" />
		<PackageReference Include="MaterialDesignThemes" Version="5.2.1" />
	</ItemGroup>

</Project>

