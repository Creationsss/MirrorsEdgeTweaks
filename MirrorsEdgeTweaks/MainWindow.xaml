<Window x:Class="MirrorsEdgeTweaks.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MirrorsEdgeTweaks"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:behaviors="clr-namespace:MirrorsEdgeTweaks.Behaviors"
        mc:Ignorable="d"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Title="Mirror's Edge Tweaks"
        Height="800" Width="650"
        Loaded="Window_Loaded"
        Icon="Icon.ico"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <materialDesign:DialogHost Identifier="RootDialog">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Click="SelectGameDirectory_Click"
                    Padding="10,5"
                    DockPanel.Dock="Right"
                    Style="{StaticResource MaterialDesignOutlinedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FolderSearchOutline"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center"/>
                    <TextBlock Text="Select Game Directory"/>
                </StackPanel>
            </Button>
            <Border BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1"
                    Margin="0,0,10,0"
                    CornerRadius="4">
                <TextBlock x:Name="GameDirectoryPathTextBlock"
                           Text="No directory selected."
                           VerticalAlignment="Center"
                           Padding="5"
                           TextTrimming="CharacterEllipsis"/>
            </Border>
        </DockPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="TagOutline"
                                         VerticalAlignment="Center"
                                         Margin="0,0,5,0"
                                         Opacity="0.7"/>
                <TextBlock x:Name="GameVersionTextBlock"
                           Text="Game Version: N/A"
                           Opacity="0.7"/>
            </StackPanel>
            <Separator Style="{StaticResource MaterialDesignLightSeparator}" Margin="16,0"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="FileDocumentOutline"
                                         VerticalAlignment="Center"
                                         Margin="0,0,5,0"
                                         Opacity="0.7"/>
                <TextBlock x:Name="ConfigStatusTextBlock"
                           Text="Documents Configs: N/A"
                           Opacity="0.7"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5,10,0,30">
            <Button Click="LaunchGame_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Margin="0,0,10,0"
                    Height="28"
                    Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Play" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Launch Game" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Click="LaunchGameWithArgs_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Height="28"
                    Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Play" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Launch Game w/ Args" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Border Grid.Row="3" BorderBrush="LightGray" BorderThickness="0,2,0,0" Margin="0,0,0,0">
            <TabControl x:Name="MainTabControl" Margin="0,0,0,10"
                    BorderThickness="0"
                    Padding="0"
                    KeyboardNavigation.TabNavigation="None">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource MaterialDesignTabItem}">
                    <Setter Property="Background" Value="{DynamicResource PrimaryHueDarkBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryHueDarkForegroundBrush}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="GamepadVariant"
                                                 Margin="0,0,6,0"/>
                        <TextBlock Text="Game Tweaks" FontWeight="Bold"/>
                    </StackPanel>
                </TabItem.Header>

                <Border Background="White" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  behaviors:SmoothScrollBehavior.SmoothScroll="True"
                                  behaviors:SmoothScrollBehavior.FadeEdges="True"
                                  Focusable="False">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer" BasedOn="{StaticResource MaterialDesignScrollViewer}">
                                <Style.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBar}" />
                                </Style.Resources>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel x:Name="GameTweaksGrid" TextElement.Foreground="Black" Margin="0,0,15,0" 
                                    Focusable="False" KeyboardNavigation.TabNavigation="None">

                            <!-- Mods Header -->
                            <Border Background="{DynamicResource PrimaryHueLightBrush}" 
                                    CornerRadius="4" Padding="10,5" Margin="0,0,0,10">
                                <TextBlock Text="Mods" FontWeight="Bold" FontSize="16" 
                                           Foreground="White" VerticalAlignment="Center"/>
                            </Border>

                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="TdGame Version:" VerticalAlignment="Center"
                                           FontWeight="Bold" Margin="0,0,36,0"/>
                                <ComboBox Grid.Column="1" x:Name="TdGameVersionComboBox"
                                          VerticalAlignment="Center"
                                          Style="{StaticResource MaterialDesignComboBox}"
                                          SelectionChanged="TdGameVersionComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Original"/>
                                    <ComboBoxItem Content="TdGame Fix (by Keku)"/>
                                    <ComboBoxItem Content="Time Trials Timer Fix (by Nulaft)"/>
                                    <ComboBoxItem Content="TdGame Fix + Time Trials Timer Fix"/>
                                </ComboBox>
                                <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Information"
                                        Margin="5,0,0,0"
                                        Click="ShowTdGameVersionInfo_Click">
                                    <materialDesign:PackIcon Kind="Information" />
                                </Button>
                            </Grid>

                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Developer Console:" VerticalAlignment="Center"
                                           FontWeight="Bold" MinWidth="140" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="InstallConsoleButton" Content="Install"
                                            Click="InstallConsole_Click"
                                            Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,10,0"/>
                                    <Button x:Name="UninstallConsoleButton" Content="Uninstall"
                                            Click="UninstallConsole_Click"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                    <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                                            BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock x:Name="ConsoleStatus" Text="N/A" 
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    </Border>
                                </StackPanel>
                                <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Information"
                                        Margin="5,0,0,0"
                                        Click="ShowConsoleInfo_Click">
                                    <materialDesign:PackIcon Kind="Information" />
                                </Button>
                            </Grid>

                            <Border Margin="0,15,0,0"
                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,10,10,8"
                                    Background="#0D000000">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="179"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Tweaks Scripts:" VerticalAlignment="Center"
                                                   FontWeight="Bold" MinWidth="129" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button x:Name="InstallTweaksScriptsButton" Content="Install"
                                                    Click="InstallTweaksScripts_Click"
                                                    Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,10,0"/>
                                            <Button x:Name="UninstallTweaksScriptsButton" Content="Uninstall"
                                                    Click="UninstallTweaksScripts_Click"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                    BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Name="TweaksScriptsStatus" Text="N/A" 
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                            </Border>
                                        </StackPanel>
                                        <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="Information"
                                                Margin="5,0,0,0"
                                                Click="ShowTweaksScriptsInfo_Click">
                                            <materialDesign:PackIcon Kind="Information" />
                                        </Button>
                                    </Grid>

                                    <StackPanel x:Name="TweaksScriptsUIInstallDependencyPanel" Margin="0,10,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="179"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Tweaks Scripts UI:" VerticalAlignment="Center"
                                                       FontWeight="Bold" MinWidth="129" Margin="0,0,10,0"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button x:Name="InstallTweaksScriptsUIButton" Content="Install"
                                                        Click="InstallTweaksScriptsUI_Click"
                                                        ToolTip="Install Tweaks Scripts first to enable this installer."
                                                        ToolTipService.ShowOnDisabled="True"
                                                        Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,10,0"/>
                                                <Button x:Name="UninstallTweaksScriptsUIButton" Content="Uninstall"
                                                        Click="UninstallTweaksScriptsUI_Click"
                                                        Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                        BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="10,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock x:Name="TweaksScriptsUIStatus" Text="N/A" 
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                                </Border>
                                            </StackPanel>
                                            <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="Information"
                                                    Margin="5,0,0,0"
                                                    Click="ShowTweaksScriptsUIInfo_Click">
                                                <materialDesign:PackIcon Kind="Information" />
                                            </Button>
                                        </Grid>
                                        <TextBlock x:Name="TweaksScriptsUIRequiresScriptsText"
                                                   Text="Install 'Tweaks Scripts' first to enable Tweaks Scripts UI installation."
                                                   Margin="0,6,0,0"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Separator Margin="0,20" Style="{StaticResource MaterialDesignDarkSeparator}"/>

                            <!-- Patches Header -->
                            <Border Background="{DynamicResource PrimaryHueLightBrush}" 
                                    CornerRadius="4" Padding="10,5" Margin="0,0,0,10">
                                <TextBlock Text="Patches" FontWeight="Bold" FontSize="16" 
                                           Foreground="White" VerticalAlignment="Center"/>
                            </Border>

                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Unlocked Configs:" VerticalAlignment="Center"
                                           FontWeight="Bold" MinWidth="140" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="PatchConfigsButton" Content="Patch"
                                            Click="PatchConfigs_Click"
                                            Style="{StaticResource MaterialDesignRaisedButton}" Width="70" Margin="0,0,10,0"/>
                                    <Button x:Name="UnpatchConfigsButton" Content="Unpatch"
                                            Click="UnpatchConfigs_Click"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Width="87"/>
                                    <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                                            BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="UnlockedConfigsStatus" Text="N/A"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    </Border>
                                </StackPanel>
                                <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Information"
                                        Margin="5,0,0,0"
                                        Click="ShowUnlockedConfigsInfo_Click">
                                    <materialDesign:PackIcon Kind="Information" />
                                </Button>
                            </Grid>

                            <StackPanel Margin="0,15,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Launch Arguments:" VerticalAlignment="Center"
                                               FontWeight="Bold" MinWidth="140" Margin="0,0,10,0"/>
                                    <TextBox x:Name="LaunchArgumentsTextBox"
                                             Grid.Row="1"
                                             Grid.Column="0"
                                             Grid.ColumnSpan="3"
                                             Margin="0,8,0,0"
                                             VerticalAlignment="Center"
                                             Style="{StaticResource MaterialDesignTextBox}"
                                             materialDesign:HintAssist.Hint="Enter launch arguments"/>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Patch"
                                                Click="ApplyLaunchArguments_Click"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Width="70"
                                                Margin="0,0,10,0"/>
                                        <Button Content="Unpatch"
                                                Click="ResetLaunchArguments_Click"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Width="87"/>
                                    </StackPanel>
                                    <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Information"
                                            Margin="5,0,0,0"
                                            Click="ShowLaunchArgumentsInfo_Click">
                                        <materialDesign:PackIcon Kind="Information" />
                                    </Button>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="1"
                                            Grid.ColumnSpan="3"
                                            Background="{DynamicResource MaterialDesignCardBackground}"
                                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,2"
                                            HorizontalAlignment="Left">
                                        <TextBlock x:Name="LaunchArgumentsPatchStatusTextBlock"
                                                   Text="N/A"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </Grid>
                            </StackPanel>

                            <!-- Other Patches -->
                            <Expander Margin="0,25,0,0"
                                      IsExpanded="False"
                                      HorizontalAlignment="Stretch"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Style="{StaticResource MaterialDesignExpander}"
                                      materialDesign:ExpanderAssist.HorizontalHeaderPadding="0">
                                <Expander.Header>
                                    <TextBlock Text="Other Patches"
                                               FontWeight="SemiBold" FontSize="13"
                                               Foreground="{DynamicResource MaterialDesignBodyDark}"/>
                                </Expander.Header>
                                <StackPanel Margin="0,10,0,0">

                                    <!-- Enable Logging -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="190"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Enable Logging:" VerticalAlignment="Center"
                                                   FontWeight="Bold" MinWidth="140" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button x:Name="PatchLoggingButton" Content="Patch"
                                                    Click="PatchLogging_Click"
                                                    Style="{StaticResource MaterialDesignRaisedButton}" Width="70" Margin="0,0,10,0"/>
                                            <Button x:Name="UnpatchLoggingButton" Content="Unpatch"
                                                    Click="UnpatchLogging_Click"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}" Width="87"/>
                                            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                    BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Name="LoggingPatchStatusTextBlock"
                                                           Text="N/A"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                            </Border>
                                        </StackPanel>
                                        <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="Information"
                                                Margin="5,0,0,0"
                                                Click="ShowLoggingInfo_Click">
                                            <materialDesign:PackIcon Kind="Information" />
                                        </Button>
                                    </Grid>

                                    <!-- Multi-instance -->
                                    <Grid Margin="0,15,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="190"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Multi-instance:" VerticalAlignment="Center"
                                                   FontWeight="Bold" MinWidth="140" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button x:Name="PatchMultiInstanceButton" Content="Patch"
                                                    Click="PatchMultiInstance_Click"
                                                    Style="{StaticResource MaterialDesignRaisedButton}" Width="70" Margin="0,0,10,0"/>
                                            <Button x:Name="UnpatchMultiInstanceButton" Content="Unpatch"
                                                    Click="UnpatchMultiInstance_Click"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}" Width="87"/>
                                            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                    BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Name="MultiInstancePatchStatusTextBlock"
                                                           Text="N/A"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                            </Border>
                                        </StackPanel>
                                        <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="Information"
                                                Margin="5,0,0,0"
                                                Click="ShowMultiInstanceInfo_Click">
                                            <materialDesign:PackIcon Kind="Information" />
                                        </Button>
                                    </Grid>

                                    <!-- Ambiguous Bypass -->
                                    <Grid Margin="0,15,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="190"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Ambiguous Bypass:" VerticalAlignment="Center"
                                                   FontWeight="Bold" MinWidth="140" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button x:Name="PatchAmbiguousBypassButton" Content="Patch"
                                                    Click="PatchAmbiguousBypass_Click"
                                                    Style="{StaticResource MaterialDesignRaisedButton}" Width="70" Margin="0,0,10,0"/>
                                            <Button x:Name="UnpatchAmbiguousBypassButton" Content="Unpatch"
                                                    Click="UnpatchAmbiguousBypass_Click"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}" Width="87"/>
                                            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                    BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Name="AmbiguousBypassPatchStatusTextBlock"
                                                           Text="N/A"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                            </Border>
                                        </StackPanel>
                                        <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="Information"
                                                Margin="5,0,0,0"
                                                Click="ShowAmbiguousBypassInfo_Click">
                                            <materialDesign:PackIcon Kind="Information" />
                                        </Button>
                                    </Grid>

                                </StackPanel>
                            </Expander>
                            
                            <Separator Margin="0,20" Style="{StaticResource MaterialDesignDarkSeparator}"/>
                            
                            <!-- Audio Settings Header -->
                            <Border Background="{DynamicResource PrimaryHueLightBrush}" 
                                    CornerRadius="4" Padding="10,5" Margin="0,0,0,10">
                                <TextBlock Text="Audio Settings" FontWeight="Bold" FontSize="16" 
                                           Foreground="White" VerticalAlignment="Center"/>
                            </Border>
                            
                            <!-- Game Language Setting -->
                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Game Language:" VerticalAlignment="Center"
                                           FontWeight="Bold" Margin="0,0,36,0" Foreground="Black"/>
                                <ComboBox Grid.Column="1" x:Name="GameLanguageComboBox"
                                          VerticalAlignment="Center"
                                          Style="{StaticResource MaterialDesignComboBox}"
                                          Foreground="Black"
                                          SelectionChanged="GameLanguageComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Čeština (CZE)" Foreground="Black"/>
                                    <ComboBoxItem Content="Deutsch (DEU)" Foreground="Black"/>
                                    <ComboBoxItem Content="English (INT)" Foreground="Black"/>
                                    <ComboBoxItem Content="Español (ESN)" Foreground="Black"/>
                                    <ComboBoxItem Content="Français (FRA)" Foreground="Black"/>
                                    <ComboBoxItem Content="Italiano (ITA)" Foreground="Black"/>
                                    <ComboBoxItem Content="Magyar (HUN)" Foreground="Black"/>
                                    <ComboBoxItem Content="Polski (POL)" Foreground="Black"/>
                                    <ComboBoxItem Content="Português (POR)" Foreground="Black"/>
                                    <ComboBoxItem Content="Русский (RUS)" Foreground="Black"/>
                                    <ComboBoxItem Content="한국어 (KOR)" Foreground="Black"/>
                                    <ComboBoxItem Content="台灣繁體中文 (CHT)" Foreground="Black"/>
                                    <ComboBoxItem Content="日本語 (JPN)" Foreground="Black"/>
                                    <ComboBoxItem Content="简体中文 (CHS)" Foreground="Black"/>
                                </ComboBox>
                                <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Information"
                                        Margin="5,0,0,0"
                                        Click="ShowGameLanguageInfo_Click">
                                    <materialDesign:PackIcon Kind="Information" />
                                </Button>
                            </Grid>
                            
                            <!-- Audio Backend Setting -->
                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Audio Backend:" VerticalAlignment="Center"
                                           FontWeight="Bold" Margin="0,0,43,0" Foreground="Black"/>
                                <ComboBox Grid.Column="1" x:Name="AudioBackendComboBox"
                                          VerticalAlignment="Center"
                                          Style="{StaticResource MaterialDesignComboBox}"
                                          Foreground="Black"
                                          SelectionChanged="AudioBackendComboBox_SelectionChanged">
                                    <ComboBoxItem Content="OpenAL (default)" Foreground="Black"/>
                                    <ComboBoxItem Content="OpenAL Soft (modern)" Foreground="Black"/>
                                    <ComboBoxItem Content="OpenAL Soft (HRTF)" Foreground="Black"/>
                                </ComboBox>
                                <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Information"
                                        Margin="5,0,0,0"
                                        Click="ShowAudioBackendInfo_Click">
                                    <materialDesign:PackIcon Kind="Information" />
